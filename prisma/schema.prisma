generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_job_logs {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  audit_job_id String     @db.Uuid
  step         String?    @db.VarChar(100)
  status       String?    @db.VarChar(50)
  message      String?
  metadata     Json?      @default("{}")
  created_at   DateTime?  @default(now()) @db.Timestamptz(6)
  audit_jobs   audit_jobs @relation(fields: [audit_job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_jobs {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id         String              @db.Uuid
  created_by        String?             @db.Uuid
  year              Int
  status            String?             @default("PENDING") @db.VarChar(50)
  risk_level        String?             @db.VarChar(50)
  total_errors      Int?                @default(0)
  started_at        DateTime?           @db.Timestamptz(6)
  completed_at      DateTime?           @db.Timestamptz(6)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  audit_job_logs    audit_job_logs[]
  clients           clients             @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             users?              @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  audit_results     audit_results[]
  generated_reports generated_reports[]
  uploaded_files    uploaded_files[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_results {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  audit_job_id   String       @db.Uuid
  rule_id        String?      @db.Uuid
  month          Int?
  product_code   String?      @db.VarChar(100)
  product_name   String?
  error_type     String?      @db.VarChar(255)
  description    String?
  recommendation String?
  risk_level     String?      @db.VarChar(50)
  metadata       Json?        @default("{}")
  created_at     DateTime?    @default(now()) @db.Timestamptz(6)
  audit_jobs     audit_jobs   @relation(fields: [audit_job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  audit_rules    audit_rules? @relation(fields: [rule_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_rules {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String          @unique @db.VarChar(50)
  name          String          @db.VarChar(255)
  description   String?
  risk_level    String?         @db.VarChar(50)
  is_active     Boolean?        @default(true)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  audit_results audit_results[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model clients {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id    String       @db.Uuid
  business_name String       @db.VarChar(255)
  ruc           String?      @db.VarChar(20)
  email         String?      @db.VarChar(255)
  phone         String?      @db.VarChar(50)
  status        String?      @default("ACTIVE") @db.VarChar(50)
  created_at    DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?    @default(now()) @db.Timestamptz(6)
  audit_jobs    audit_jobs[]
  companies     companies    @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model companies {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @db.VarChar(255)
  ruc        String?   @db.VarChar(20)
  email      String?   @db.VarChar(255)
  phone      String?   @db.VarChar(50)
  status     String?   @default("ACTIVE") @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  clients    clients[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model generated_reports {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  audit_job_id String     @db.Uuid
  report_type  String?    @db.VarChar(50)
  s3_key       String
  generated_at DateTime?  @default(now()) @db.Timestamptz(6)
  audit_jobs   audit_jobs @relation(fields: [audit_job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model uploaded_files {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  audit_job_id String     @db.Uuid
  file_type    String     @db.VarChar(50)
  month        Int?
  file_name    String     @db.VarChar(255)
  s3_key       String
  file_size    BigInt?
  status       String?    @default("UPLOADED") @db.VarChar(50)
  uploaded_at  DateTime?  @default(now()) @db.Timestamptz(6)
  audit_jobs   audit_jobs @relation(fields: [audit_job_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cognito_sub String?      @unique @db.VarChar(255)
  email       String       @db.VarChar(255)
  full_name   String?      @db.VarChar(255)
  role        String       @db.VarChar(50)
  status      String?      @default("ACTIVE") @db.VarChar(50)
  created_at  DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?    @default(now()) @db.Timestamptz(6)
  audit_jobs  audit_jobs[]
}
